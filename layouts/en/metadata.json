{
    "KPlugin": {
        "Id": "org.kde.plasma.keyboard.en",
        "Name": "English"
    },
    "X-Plasma-Keyboard": {
        "Locales": [
            "en_US",
            "en_GB"
        ],
        "KeyboardLayouts": [
            {
                "Id": "mobile-qwerty",
                "Name": "QWERTY",
                "Files": {
                    "main": "MobileQwerty.qml",
                    "symbols": "shared/Symbols.qml",
                    "digits": "shared/Digits.qml",
                    "numbers": "shared/Numbers.qml",
                    "dialpad": "shared/Dialpad.qml"
                },
                "FormFactors": [
                    "phone",
                    "mediacenter",
                    "desktop"
                ]
            },
            {
                "Id": "desktop-qwerty",
                "Name": "QWERTY (Desktop)",
                "Files": {
                    "main": "DesktopQwerty.qml",
                    "symbols": "shared/Symbols.qml",
                    "digits": "shared/Digits.qml",
                    "numbers": "shared/Numbers.qml",
                    "dialpad": "shared/Dialpad.qml"
                },
                "FormFactors": [
                    "desktop"
                ]
            },
            {
                "Id": "desktop-full-qwerty",
                "Name": "QWERTY (Full Desktop)",
                "Files": {
                    "main": "FullQwerty.qml",
                    "symbols": "shared/Symbols.qml",
                    "digits": "shared/Digits.qml",
                    "numbers": "shared/Numbers.qml",
                    "dialpad": "shared/Dialpad.qml"
                },
                "FormFactors": [
                    "desktop"
                ]
            },
            {
                "Id": "mobile-dvorak",
                "Name": "Dvorak",
                "Files": {
                    "main": "MobileDvorak.qml",
                    "symbols": "shared/Symbols.qml",
                    "digits": "shared/Digits.qml",
                    "numbers": "shared/Numbers.qml",
                    "dialpad": "shared/Dialpad.qml"
                },
                "FormFactors": [
                    "phone",
                    "mediacenter",
                    "desktop"
                ]
            }
        ]
    }
}
